# Hostinger VPS — nginx site for skilz.pk
# Install: sudo cp deploy/hostinger/nginx-skilz.pk.conf.example /etc/nginx/sites-available/skilz.pk
#          sudo ln -sf /etc/nginx/sites-available/skilz.pk /etc/nginx/sites-enabled/
#          sudo nginx -t && sudo systemctl reload nginx
#
# Prerequisite: Node app running on 127.0.0.1:3000 (PM2 — see ecosystem.config.cjs)

# Redirect HTTP → HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name skilz.pk www.skilz.pk;
    return 301 https://$host$request_uri;
}

# Main HTTPS — proxy EVERYTHING to Express (SPA + /api + Socket.IO)
# This matches local production test: NODE_ENV=production npm run start on :3000
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name skilz.pk www.skilz.pk;

    # Certbot (Let's Encrypt) — paths appear after: sudo certbot --nginx -d skilz.pk -d www.skilz.pk
    ssl_certificate     /etc/letsencrypt/live/skilz.pk/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/skilz.pk/privkey.pem;
    include             /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;

    client_max_body_size 25m;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Socket.IO long-polling + WebSocket upgrade
    location /socket.io/ {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400;
    }
}
