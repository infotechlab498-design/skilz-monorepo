# Copy to /var/www/skilz/.env on your Hostinger VPS (never commit real secrets).
# Paths like FIREBASE_SERVICE_ACCOUNT_PATH resolve from backend/ at runtime.

NODE_ENV=production
PORT=3000

# Long random string — required for auth middleware
JWT_SECRET=replace-with-openssl-rand-hex-32

# Public site URL (used in emails/links where applicable)
APP_URL=https://skilz.pk
APP_BASE_URL=https://skilz.pk

# Firebase Admin — upload JSON to backend/secrets/ on the server
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/skilz-firebase-adminsdk.json
FIREBASE_PROJECT_ID=skilz-63d0a
FIREBASE_DATABASE_URL=https://skilz-63d0a-default-rtdb.asia-southeast1.firebasedatabase.app
FIREBASE_WEB_API_KEY=your-firebase-web-api-key

# Admin dashboard (Firestore users/{uid}.role or email match)
ADMIN_EMAIL=your-admin@example.com

# Socket.IO CORS — same domain as site (omit VITE_SOCKET_URL in frontend build)
SOCKET_CORS_ORIGINS=https://skilz.pk,https://www.skilz.pk

# Optional: Cloudinary for profile/payment uploads
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Build-time vars (also set before `npm run build` — Vite reads root .env)
VITE_FIREBASE_DATABASE_URL=https://skilz-63d0a-default-rtdb.asia-southeast1.firebasedatabase.app
VITE_FIREBASE_FUNCTIONS_REGION=us-central1
# Do NOT set VITE_SOCKET_URL when API and site share skilz.pk
