# Skilz monorepo — environment variables
#
# Option A: Single file at repo root (convenient for local dev).
#   The backend loads `../.env` then `backend/.env`. Vite loads from `frontend/` only — copy
#   VITE_* and GEMINI_* into `frontend/.env` OR keep them here and symlink / duplicate as needed.
#
# Option B: Split files (recommended for clarity):
#   - See `backend/.env.example`  (server, Firebase Admin, JWT)
#   - See `frontend/.env.example` (VITE_*, GEMINI_API_KEY)

# --- Backend-oriented (also loaded by `backend/src/server.js` when present at repo root) ---
# PORT=3001
# If you override PORT for dev, set the same port in `frontend/vite.config.js` proxy targets.
# JWT_SECRET="change-me-in-production"
# GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
# APP_URL="MY_APP_URL"
# FIREBASE_SERVICE_ACCOUNT_PATH=./backend/secrets/your-service-account.json
# FIREBASE_WEB_API_KEY=
# FIREBASE_SYNC_WALLET=0
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# --- Frontend (must be in `frontend/.env` for Vite, or use a tool to sync) ---
# VITE_FIREBASE_API_KEY=
# Optional: Socket.IO URL for production or when the API is on another host.
# Omit in local dev — the client uses same-origin + Vite’s `/socket.io` proxy (see frontend/vite.config.js).
# VITE_SOCKET_URL=https://your-api.example.com
# VITE_FIREBASE_FUNCTIONS_REGION=us-central1
# VITE_USE_FUNCTIONS_EMULATOR=true


# Trivia one-shot generation with fallback chain:
# Order: PRIMARY -> SECONDARY -> OpenTDB
# Supported providers for PRIMARY/SECONDARY: gemini | openai
#
# PRIMARY (defaults to gemini if unset)
# TRIVIA_AI_PRIMARY_PROVIDER=gemini
# TRIVIA_AI_PRIMARY_MODEL=gemini-2.5-flash
# TRIVIA_AI_PRIMARY_API_KEY=
# TRIVIA_AI_PRIMARY_TIMEOUT_MS=12000
# Optional custom endpoint (OpenAI-compatible or proxy):
# TRIVIA_AI_PRIMARY_BASE_URL=
#
# SECONDARY (defaults to opposite provider if unset)
# TRIVIA_AI_SECONDARY_PROVIDER=openai
# TRIVIA_AI_SECONDARY_MODEL=gpt-4o-mini
# TRIVIA_AI_SECONDARY_API_KEY=
# TRIVIA_AI_SECONDARY_TIMEOUT_MS=12000
# Optional custom endpoint:
# TRIVIA_AI_SECONDARY_BASE_URL=
#
# Legacy single-provider keys (optional backward compatibility)
# TRIVIA_AI_PROVIDER=gemini
# TRIVIA_AI_MODEL=gemini-2.5-flash
# TRIVIA_AI_API_KEY=
# TRIVIA_AI_TIMEOUT_MS=12000
# TRIVIA_AI_BASE_URL=
#
# Chunked generation resilience
# TRIVIA_AI_BATCH_SIZE=3
# TRIVIA_AI_MIN_BATCH_SIZE=1
# TRIVIA_AI_CHUNK_RETRIES=2
#
# OpenTDB fallback (third attempt)
# TRIVIA_OPENTDB_ENABLED=1
# TRIVIA_OPENTDB_BASE_URL=https://opentdb.com/api.php
# TRIVIA_OPENTDB_TIMEOUT_MS=12000