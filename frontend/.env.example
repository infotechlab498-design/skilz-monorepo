# Copy to `frontend/.env` or use monorepo root `.env` (Vite loads from `frontend/` via vite.config).

# GEMINI_API_KEY= (used in Vite define for client)

# Optional. Omit in local dev to use the page origin so Socket.IO goes through Vite’s `/socket.io` proxy (same as `/api`).
# Set when the realtime API is on another host, e.g. VITE_SOCKET_URL=https://api.example.com
# VITE_SOCKET_URL=http://127.0.0.1:3000

# Optional: self-hosted PeerJS broker for lobby voice (see LobbyVoiceChat.jsx). If unset, PeerJS default cloud broker is used.
# VITE_PEERJS_HOST=peer.example.com
# VITE_PEERJS_PORT=443
# VITE_PEERJS_PATH=/peerjs
# VITE_PEERJS_SECURE=1
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# Realtime Database URL (must match the instance in Firebase Console)
# VITE_FIREBASE_DATABASE_URL=https://skilz-63d0a-default-rtdb.firebaseio.com

# VITE_LEGACY_SIGNUP=
# VITE_ENABLE_DEV_CONSOLE_OTP=
# VITE_SHOW_SMS_DELIVERY_HELP=
# VITE_FIREBASE_DISABLE_APP_VERIFICATION=
VITE_FIREBASE_FUNCTIONS_REGION=us-central1
# VITE_USE_FUNCTIONS_EMULATOR=true
# VITE_AUTH_DIAGNOSTICS=dev
# Dev: Google/Facebook use popup (reliable on localhost). Set false to force redirect.
# VITE_OAUTH_USE_POPUP=true
